<%- layout("/layouts/mainboilerplate.ejs")%>

<!-- HERO -->
<section class="hero-redesign">
  <div class="hero-content">
    <div class="hero-badge">✦ 50,000+ Opportunities Listed</div>
    <h1>Launch Your Career with the Right <em>Internship</em></h1>
    <p>Find internships and fresher jobs from top companies across India. Get hired in tech, design, marketing, and 50+ other fields.</p>
    <div class="hero-ctas">
      <a href="#jobs" class="btn-redesign btn-primary-redesign btn-large"><i class="fas fa-search"></i> Find Internships</a>
      <a href="/company" class="btn-redesign btn-ghost-redesign btn-large"><i class="fas fa-building"></i> For Employers</a>
    </div>
    <div class="hero-stats">
      <div class="stat">
        <div class="stat-num">50K+</div>
        <div class="stat-label">Live Opportunities</div>
      </div>
      <div class="stat">
        <div class="stat-num">12K+</div>
        <div class="stat-label">Companies</div>
      </div>
      <div class="stat">
        <div class="stat-num">2L+</div>
        <div class="stat-label">Students Placed</div>
      </div>
    </div>
  </div>
 
  <!-- FLOATING CARDS VISUAL -->
  <div class="hero-visual">
    <div class="hero-card-stack">
      <!-- Main job card -->
      <div class="floating-card card-main">
        <div class="company-logo-row">
          <div class="company-icon" style="background:#e8f4fd;">🏢</div>
          <div>
            <div class="company-name">Google India</div>
            <div class="company-sub">Technology · Bengaluru</div>
          </div>
        </div>
        <div style="font-family:'Clash Display',sans-serif;font-size:1.05rem;font-weight:700;margin-bottom:4px;">Software Engineer Intern</div>
        <div class="tag-row">
          <span class="tag tag-blue">React</span>
          <span class="tag tag-blue">Python</span>
          <span class="tag tag-green">Remote</span>
          <span class="tag tag-orange">6 Months</span>
        </div>
        <div class="salary-row">
          <div class="salary">₹45,000 <span>/ month</span></div>
          <button class="apply-mini-btn">Apply Now</button>
        </div>
      </div>
      <!-- Mini card 1 -->
      <div class="floating-card card-mini-1">
        <div class="mini-card-content">
          <div style="font-size:1.4rem;">🎨</div>
          <div class="mini-title">UI/UX Designer</div>
          <div class="mini-sub">Razorpay · Mumbai</div>
          <span class="tag tag-green" style="font-size:0.68rem;padding:3px 8px;">₹30K/mo</span>
        </div>
      </div>
      <!-- Mini card 2 -->
      <div class="floating-card card-mini-2">
        <div class="mini-card-content">
          <div style="font-size:1.4rem;">📈</div>
          <div class="mini-title">Growth Intern</div>
          <div class="mini-sub">Swiggy · Delhi</div>
          <div style="display:flex;gap:4px;margin-top:4px;">
            <span class="tag tag-orange" style="font-size:0.68rem;padding:3px 8px;">Marketing</span>
            <span class="tag tag-green" style="font-size:0.68rem;padding:3px 8px;">Remote</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
 
<!-- SEARCH -->
<div class="search-section">
  <div class="search-box fade-in">
    <i class="fas fa-search" style="color:#bbb;font-size:1rem;"></i>
    <input type="text" placeholder="Job title, skill, or company...">
    <div class="search-divider"></div>
    <select class="search-select">
      <option>All Locations</option>
      <option>Bengaluru</option>
      <option>Mumbai</option>
      <option>Delhi</option>
      <option>Hyderabad</option>
      <option>Remote</option>
    </select>
    <div class="search-divider"></div>
    <select class="search-select">
      <option>All Categories</option>
      <option>Technology</option>
      <option>Design</option>
      <option>Marketing</option>
      <option>Finance</option>
    </select>
    <button class="btn-redesign btn-primary-redesign" style="flex-shrink:0;padding:12px 28px;">Search Jobs</button>
  </div>
</div>
 
<!-- MARQUEE -->
<div class="marquee-section">
  <div class="marquee-track">
    <div class="marquee-item"><i class="fas fa-circle"></i> Google</div>
    <div class="marquee-item"><i class="fas fa-circle"></i> Razorpay</div>
    <div class="marquee-item"><i class="fas fa-circle"></i> Swiggy</div>
    <div class="marquee-item"><i class="fas fa-circle"></i> Zomato</div>
    <div class="marquee-item"><i class="fas fa-circle"></i> Flipkart</div>
    <div class="marquee-item"><i class="fas fa-circle"></i> Meesho</div>
    <div class="marquee-item"><i class="fas fa-circle"></i> CRED</div>
    <div class="marquee-item"><i class="fas fa-circle"></i> Zepto</div>
    <div class="marquee-item"><i class="fas fa-circle"></i> PhonePe</div>
    <div class="marquee-item"><i class="fas fa-circle"></i> Paytm</div>
    <!-- Duplicate for seamless loop -->
    <div class="marquee-item"><i class="fas fa-circle"></i> Google</div>
    <div class="marquee-item"><i class="fas fa-circle"></i> Razorpay</div>
    <div class="marquee-item"><i class="fas fa-circle"></i> Swiggy</div>
    <div class="marquee-item"><i class="fas fa-circle"></i> Zomato</div>
    <div class="marquee-item"><i class="fas fa-circle"></i> Flipkart</div>
    <div class="marquee-item"><i class="fas fa-circle"></i> Meesho</div>
    <div class="marquee-item"><i class="fas fa-circle"></i> CRED</div>
    <div class="marquee-item"><i class="fas fa-circle"></i> Zepto</div>
    <div class="marquee-item"><i class="fas fa-circle"></i> PhonePe</div>
    <div class="marquee-item"><i class="fas fa-circle"></i> Paytm</div>
  </div>
</div>
 
<!-- CATEGORIES -->
<div class="section-redesign" id="categories">
  <div class="section-header-redesign fade-in">
    <div>
      <div class="section-label-redesign">Browse by Field</div>
      <div class="section-title-redesign">Explore Categories</div>
    </div>
    <a href="#" class="section-link-redesign">All Categories <i class="fas fa-arrow-right"></i></a>
  </div>
  <div class="categories-grid fade-in">
    <div class="category-card">
      <div class="cat-icon">💻</div>
      <div class="cat-title">Technology & IT</div>
      <div class="cat-count">18,240 openings</div>
      <div class="cat-arrow"><i class="fas fa-arrow-right"></i></div>
    </div>
    <div class="category-card">
      <div class="cat-icon">🎨</div>
      <div class="cat-title">Design & Creative</div>
      <div class="cat-count">6,820 openings</div>
      <div class="cat-arrow"><i class="fas fa-arrow-right"></i></div>
    </div>
    <div class="category-card">
      <div class="cat-icon">📣</div>
      <div class="cat-title">Marketing & Sales</div>
      <div class="cat-count">9,450 openings</div>
      <div class="cat-arrow"><i class="fas fa-arrow-right"></i></div>
    </div>
    <div class="category-card">
      <div class="cat-icon">📊</div>
      <div class="cat-title">Finance & Banking</div>
      <div class="cat-count">4,120 openings</div>
      <div class="cat-arrow"><i class="fas fa-arrow-right"></i></div>
    </div>
  </div>
</div>
 
<!-- INTERNSHIPS -->
<div class="section-redesign" id="jobs" style="padding-top:0">
  <div class="section-header-redesign fade-in">
    <div>
      <div class="section-label-redesign">Fresh Listings</div>
      <div class="section-title-redesign">Latest Internships</div>
    </div>
    <a href="/student/internship" class="section-link-redesign">View All <i class="fas fa-arrow-right"></i></a>
  </div>
  <div class="jobs-grid-redesign">
    <% for(let i=0; i < (internships.length < 3 ? internships.length : 3); i++){ %>
    <a href="/student/internship/<%=internships[i]._id%>" class="job-card-redesign fade-in">
      <div class="job-card-top-redesign">
        <div class="company-avatar" style="background:#e8f4fd;color:#2980b9;"><%= internships[i].title.charAt(0) %></div>
        <button class="bookmark-btn"><i class="far fa-bookmark"></i></button>
      </div>
      <div class="job-title-redesign"><%= internships[i].title %></div>
      <div class="job-company">Company · <%= internships[i].location %></div>
      <div class="tag-row">
        <span class="tag tag-blue"><%= internships[i].internshiptype %></span>
        <span class="tag tag-green">Remote</span>
      </div>
      <div class="job-meta">
        <div class="job-meta-item"><i class="far fa-clock"></i> 3 Months</div>
        <div class="job-meta-item"><i class="fas fa-graduation-cap"></i> Fresher</div>
      </div>
      <div class="job-card-footer">
        <div class="job-stipend">₹<%= internships[i].stipend %> <span>/ month</span></div>
        <div class="posted-time">Active</div>
      </div>
    </a>
    <% } %>
  </div>
</div>

<!-- JOBS -->
<div class="section-redesign" style="padding-top:0">
  <div class="section-header-redesign fade-in">
    <div>
      <div class="section-label-redesign">Career Moves</div>
      <div class="section-title-redesign">Latest Jobs</div>
    </div>
    <a href="/student/job" class="section-link-redesign">View All <i class="fas fa-arrow-right"></i></a>
  </div>
  <div class="jobs-grid-redesign">
    <% for(let i=0; i < (jobs.length < 3 ? jobs.length : 3); i++){ %>
    <a href="/student/job/<%=jobs[i]._id%>" class="job-card-redesign fade-in">
      <div class="job-card-top-redesign">
        <div class="company-avatar" style="background:#ffeee8;color:#e74c3c;"><%= jobs[i].title.charAt(0) %></div>
        <button class="bookmark-btn"><i class="far fa-bookmark"></i></button>
      </div>
      <div class="job-title-redesign"><%= jobs[i].title %></div>
      <div class="job-company">Company · <%= jobs[i].location %></div>
      <div class="tag-row">
        <span class="tag tag-orange"><%= jobs[i].jobType %></span>
        <span class="tag tag-blue">Full-time</span>
      </div>
      <div class="job-meta">
        <div class="job-meta-item"><i class="far fa-clock"></i> 1 Year Exp</div>
        <div class="job-meta-item"><i class="fas fa-graduation-cap"></i> Graduate</div>
      </div>
      <div class="job-card-footer">
        <div class="job-stipend">₹<%= jobs[i].salaryRange.min %>-<%= jobs[i].salaryRange.max %> <span>/ month</span></div>
        <div class="posted-time">Today</div>
      </div>
    </a>
    <% } %>
  </div>
</div>
 
<!-- COMPANIES -->
<div class="section-redesign" id="companies">
  <div class="section-header-redesign fade-in">
    <div>
      <div class="section-label-redesign">Top Hirers</div>
      <div class="section-title-redesign">Featured Companies</div>
    </div>
    <a href="#" class="section-link-redesign">All Companies <i class="fas fa-arrow-right"></i></a>
  </div>
  <div class="companies-grid fade-in">
    <div class="company-card">
      <div class="company-big-icon" style="background:#e8f4fd;">🏢</div>
      <div class="company-card-name">Google</div>
      <div class="company-card-roles">Technology · Bengaluru</div>
      <div class="open-roles">14 Open Roles</div>
    </div>
    <div class="company-card">
      <div class="company-big-icon" style="background:#ffeee8;">💳</div>
      <div class="company-card-name">Razorpay</div>
      <div class="company-card-roles">Fintech · Mumbai</div>
      <div class="open-roles">8 Open Roles</div>
    </div>
    <div class="company-card">
      <div class="company-big-icon" style="background:#e8f8ef;">🍜</div>
      <div class="company-card-name">Swiggy</div>
      <div class="company-card-roles">Food Delivery · Hyderabad</div>
      <div class="open-roles">22 Open Roles</div>
    </div>
    <div class="company-card">
      <div class="company-big-icon" style="background:#fff3e0;">🛒</div>
      <div class="company-card-name">Flipkart</div>
      <div class="company-card-roles">E-Commerce · Bengaluru</div>
      <div class="open-roles">18 Open Roles</div>
    </div>
  </div>
</div>
 
<!-- HOW IT WORKS -->
<div class="how-section" id="how">
  <div class="how-inner">
    <div style="text-align:center;margin-bottom:8px;" class="fade-in">
      <div class="section-label-redesign">Simple Process</div>
      <div class="section-title-redesign">How It Works</div>
    </div>
    <div class="steps-grid fade-in">
      <div class="step-card">
        <div class="step-number">01</div>
        <div class="step-icon-redesign"><i class="fas fa-user-edit"></i></div>
        <div class="step-title">Create Your Profile</div>
        <div class="step-desc">Sign up for free and build your profile with your skills, education, and experience in just 5 minutes.</div>
      </div>
      <div class="step-card">
        <div class="step-number">02</div>
        <div class="step-icon-redesign"><i class="fas fa-search"></i></div>
        <div class="step-title">Discover Opportunities</div>
        <div class="step-desc">Browse 50,000+ internships and fresher jobs filtered by your skills, location, and preferences.</div>
      </div>
      <div class="step-card">
        <div class="step-number">03</div>
        <div class="step-icon-redesign"><i class="fas fa-paper-plane"></i></div>
        <div class="step-title">Apply in One Click</div>
        <div class="step-desc">Apply to multiple positions instantly with your saved profile. Track all applications in your dashboard.</div>
      </div>
      <div class="step-card">
        <div class="step-number">04</div>
        <div class="step-icon-redesign"><i class="fas fa-handshake"></i></div>
        <div class="step-title">Get Hired!</div>
        <div class="step-desc">Hear back from companies, ace your interviews, and land your dream internship or first job.</div>
      </div>
    </div>
  </div>
</div>
 
<!-- TESTIMONIALS -->
<div class="section-redesign">
  <div class="section-header-redesign fade-in">
    <div>
      <div class="section-label-redesign">Success Stories</div>
      <div class="section-title-redesign">Students Love Us</div>
    </div>
  </div>
  <div class="testimonials-grid fade-in">
    <div class="testimonial-card-redesign">
      <div class="stars">★★★★★</div>
      <div class="testimonial-text">"Found my internship at a fintech startup within 2 weeks of signing up. The platform made it super easy to apply to multiple companies in one go. Highly recommended!"</div>
      <div class="testimonial-author">
        <div class="author-avatar" style="background:var(--accent);">P</div>
        <div>
          <div class="author-name">Priya Sharma</div>
          <div class="author-role">CS Student · IIT Delhi</div>
        </div>
      </div>
    </div>
    <div class="testimonial-card-redesign">
      <div class="stars">★★★★★</div>
      <div class="testimonial-text">"The filters are incredibly useful — I found remote, paid internships matching my exact skills. Got my first job offer through ApnaIntern!"</div>
      <div class="testimonial-author">
        <div class="author-avatar" style="background:var(--blue);">R</div>
        <div>
          <div class="author-name">Rahul Gupta</div>
          <div class="author-role">MBA · XLRI Jamshedpur</div>
        </div>
      </div>
    </div>
    <div class="testimonial-card-redesign">
      <div class="stars">★★★★★</div>
      <div class="testimonial-text">"As a design student, I was nervous about finding relevant opportunities. ApnaIntern had a brilliant design category with real companies looking for fresh talent."</div>
      <div class="testimonial-author">
        <div class="author-avatar" style="background:var(--green);">A</div>
        <div>
          <div class="author-name">Ananya Verma</div>
          <div class="author-role">Design · NID Ahmedabad</div>
        </div>
      </div>
    </div>
  </div>
</div>
 
<!-- CTA BANNER -->
<div class="cta-banner-redesign fade-in">
  <div class="cta-text-redesign">
    <h2>Ready to Start Your Career Journey?</h2>
    <p>Join 2 lakh+ students who found their dream internship through ApnaIntern</p>
  </div>
  <div class="cta-actions-redesign">
    <a href="/signup" class="btn-redesign btn-white btn-large"><i class="fas fa-rocket"></i> Get Started Free</a>
    <a href="/company" class="btn-redesign btn-outline-white btn-large"><i class="fas fa-building"></i> Post a Job</a>
  </div>
</div>