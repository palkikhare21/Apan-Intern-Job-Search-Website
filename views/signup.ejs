<%- layout("/layouts/mainboilerplate.ejs") %>

<div class="auth-section">
    <div class="auth-bg-gradient"></div>
    
    <div class="auth-container-redesign">
        <div class="auth-card-redesign fade-in">
            <div class="auth-header-redesign">
                <div class="hero-badge" style="margin-left:auto;margin-right:auto;">✦ Create Your Future</div>
                <h2>Sign Up as a <%= usertype.charAt(0).toUpperCase() + usertype.slice(1) %></h2>
                <p>Join thousands of others on ApnaIntern. Create your account and explore endless opportunities.</p>
            </div>

            <form method="POST" action="/signup" class="form-redesign" novalidate>
                <!-- HIDDEN USERTYPE FIELD: Crucial fix for Vercel deployment -->
                <input type="hidden" name="usertype" value="<%= usertype %>">

                <div class="form-group-redesign">
                    <label for="username">Username</label>
                    <input id="username" name="username" placeholder="Choose a username" type="text" required>
                </div>

                <div class="form-group-redesign">
                    <label for="email">Email Address</label>
                    <input id="email" name="email" placeholder="you@example.com" type="email" required>
                </div>
                
                <div class="form-group-redesign">
                    <label for="password">Password</label>
                    <input id="password" name="password" placeholder="••••••••" type="password" required>
                </div>

                <button class="btn-redesign btn-primary-redesign" style="width:100%;justify-content:center;margin-top:10px;padding:14px;">
                    <i class="fas fa-user-plus"></i> Create Account
                </button>
            </form>

            <div class="auth-footer">
                Already have an account? <a href="/login">Login here</a>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const fades = document.querySelectorAll('.fade-in');
        fades.forEach((el, index) => {
            setTimeout(() => {
                el.classList.add('visible');
            }, 150 * index);
        });
    });
</script>