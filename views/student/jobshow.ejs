<%- layout("/layouts/mainboilerplate.ejs") %>

<div class="section-redesign">
    <div class="section-header-redesign fade-in">
        <div>
            <div class="section-label-redesign">Job Opportunity</div>
            <h1 class="section-title-redesign"><%= job.title %></h1>
            <p class="auth-header-redesign p" style="margin-left: 0;"><%= company.companyname %> · <%= job.location %></p>
        </div>
        <a href="/student" class="section-link-redesign"><i class="fas fa-arrow-left"></i> Back to Opportunities</a>
    </div>

    <div class="row fade-in">
        <div class="col-lg-8">
            <div class="category-card" style="padding: 40px; margin-bottom: 24px;">
                <h3 class="section-title-redesign" style="font-size: 1.5rem; margin-bottom: 24px;">About the Job</h3>
                <p style="white-space: pre-line; line-height: 1.8; color: var(--muted); margin-bottom: 30px;">
                    <%= job.description %>
                </p>

                <hr style="opacity: 0.05; margin: 30px 0;">

                <h3 class="section-title-redesign" style="font-size: 1.5rem; margin-bottom: 20px;">Requirements & Responsibilities</h3>
                <p style="white-space: pre-line; line-height: 1.8; color: var(--muted);">
                    <%= job.requirement %>
                </p>

                <div style="margin-top: 40px; display: flex; gap: 20px;">
                    <% if (applied.length == 0) { %>
                        <form method="POST" action="/student/job/<%= job._id %>" style="flex-grow: 1;">
                            <button class="btn-redesign btn-primary-redesign" style="width: 100%; justify-content: center; padding: 16px; font-size: 1.1rem;">
                                <i class="fas fa-paper-plane"></i> Apply for Job
                            </button>
                        </form>
                    <% } else { %>
                        <button class="btn-redesign btn-ghost-redesign" disabled style="width: 100%; justify-content: center; padding: 16px; font-size: 1.1rem; opacity: 0.6; cursor: not-allowed; border-color: var(--green); color: var(--green);">
                            <i class="fas fa-check-circle"></i> Application Sent
                        </button>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="category-card" style="padding: 32px; margin-bottom: 24px;">
                <h3 class="section-title-redesign" style="font-size: 1.4rem; margin-bottom: 20px;">Quick Info</h3>
                
                <div style="margin-bottom: 20px;">
                    <div style="font-weight: 700; color: var(--ink); font-size: 0.8rem; text-transform: uppercase; margin-bottom: 4px;">Salary Package</div>
                    <div style="color: var(--accent); font-weight: 700; font-size: 1.2rem;">₹<%= job.salaryRange.min %> - <%= job.salaryRange.max %> <span>/ month</span></div>
                </div>

                <div style="margin-bottom: 20px;">
                    <div style="font-weight: 700; color: var(--ink); font-size: 0.8rem; text-transform: uppercase; margin-bottom: 4px;">Job Type</div>
                    <div style="color: var(--muted);"><%= job.jobType %></div>
                </div>

                <div style="margin-bottom: 20px;">
                    <div style="font-weight: 700; color: var(--ink); font-size: 0.8rem; text-transform: uppercase; margin-bottom: 4px;">Hiring Status</div>
                    <div style="color: var(--muted);"><%= job.openings %> Openings Left</div>
                </div>
            </div>

            <div class="category-card" style="padding: 30px; background: var(--paper); border: 2px dashed var(--border); text-align: center;">
                <div style="font-size: 2rem; margin-bottom: 12px;">📊</div>
                <h4 style="font-size: 1.1rem; margin-bottom: 8px;">Resume Score</h4>
                <p style="font-size: 0.85rem; color: var(--muted); line-height: 1.5;">Make sure your profile is 100% complete for a higher chance of being shortlisted!</p>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const fades = document.querySelectorAll('.fade-in');
        fades.forEach((el, index) => {
            setTimeout(() => {
                el.classList.add('visible');
            }, 100 * index);
        });
    });
</script>