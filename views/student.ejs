<%- layout("/layouts/mainboilerplate.ejs") %>

<div class="section-redesign">
    <div class="section-header-redesign fade-in">
        <div>
            <div class="section-label-redesign">Student Portal</div>
            <h1 class="section-title-redesign">Hi, <%= currUser.username.charAt(0).toUpperCase() + currUser.username.slice(1) %></h1>
            <p class="auth-header-redesign p" style="margin-left: 0;">Explore world-class opportunities and kickstart your career.</p>
        </div>
        <div class="nav-actions">
            <a href="/student/profile" class="btn-redesign btn-primary-redesign">
                <i class="fas fa-user"></i> View Profile
            </a>
            <a href="/student/myapplication" class="btn-redesign btn-ghost-redesign">
                <i class="fas fa-briefcase"></i> My Applications
            </a>
        </div>
    </div>

    <!-- STUDENT STATS -->
    <div class="hero-stats fade-in" style="margin-top: 0; margin-bottom: 60px; grid-template-columns: repeat(3, 1fr); display: grid; gap: 20px;">
        <div class="category-card" style="padding: 30px; text-align: center;">
            <div class="stat-num" style="color: var(--blue);">150+</div>
            <div class="stat-label">New Listings Today</div>
        </div>
        <div class="category-card" style="padding: 30px; text-align: center;">
            <div class="stat-num" style="color: var(--green);">50K+</div>
            <div class="stat-label">Live Opportunities</div>
        </div>
        <div class="category-card" style="padding: 30px; text-align: center;">
            <div class="stat-num" style="color: var(--accent);">2L+</div>
            <div class="stat-label">Students Placed</div>
        </div>
    </div>

    <!-- SCROLLING INTERNSHIPS -->
    <div class="section-header-redesign fade-in" style="margin-bottom: 24px;">
        <div>
            <div class="section-label-redesign">Internships</div>
            <div class="section-title-redesign" style="font-size: 1.8rem;">Explore Internships</div>
        </div>
        <a href="/student/internship" class="section-link-redesign">View All Internships <i class="fas fa-arrow-right"></i></a>
    </div>

    <div class="jobs-grid-redesign fade-in" style="display: flex; overflow-x: auto; gap: 15px; padding-bottom: 20px; scrollbar-width: none; -ms-overflow-style: none;">
        <% for(let i=0 ;i < (internships.length < 6 ? internships.length : 6); i++){ %>
            <div class="job-card-redesign" style="min-width: 320px; flex-shrink: 0;">
                <div class="job-card-top-redesign">
                    <div class="company-avatar" style="background:#e8f4fd; color:#2980b9;">
                        <%= internships[i].title.charAt(0).toUpperCase() %>
                    </div>
                    <button class="bookmark-btn"><i class="far fa-bookmark"></i></button>
                </div>
                <div class="job-title-redesign" style="font-size: 1.15rem; margin-bottom: 6px;"><%= internships[i].title %></div>
                <div class="job-company" style="margin-bottom: 14px;"><i class="fas fa-building"></i> Company · <%= internships[i].location %></div>
                <div class="tag-row">
                    <span class="tag tag-blue"><%= internships[i].internshiptype %></span>
                    <span class="tag tag-green">Paid</span>
                </div>
                <div class="job-card-footer" style="padding-top: 20px;">
                    <div class="job-stipend">₹<%= internships[i].stipend %> <span>/ mo</span></div>
                    <a href="/student/internship/<%=internships[i]._id%>" class="btn-redesign btn-ghost-redesign" style="padding: 8px 16px; font-size: 0.8rem;">View Details</a>
                </div>
            </div>
        <% } %>
    </div>

    <div style="height: 60px;"></div>

    <!-- SCROLLING JOBS -->
    <div class="section-header-redesign fade-in" style="margin-bottom: 24px;">
        <div>
            <div class="section-label-redesign">Jobs</div>
            <div class="section-title-redesign" style="font-size: 1.8rem;">Explore Jobs</div>
        </div>
        <a href="/student/job" class="section-link-redesign">View All Jobs <i class="fas fa-arrow-right"></i></a>
    </div>

    <div class="jobs-grid-redesign fade-in" style="display: flex; overflow-x: auto; gap: 15px; padding-bottom: 20px; scrollbar-width: none; -ms-overflow-style: none;">
        <% for(let i=0 ;i < (jobs.length < 6 ? jobs.length : 6); i++){ %>
            <div class="job-card-redesign" style="min-width: 320px; flex-shrink: 0;">
                <div class="job-card-top-redesign">
                    <div class="company-avatar" style="background:#fff3e0; color:#e67e22;">
                        <%= jobs[i].title.charAt(0).toUpperCase() %>
                    </div>
                    <button class="bookmark-btn"><i class="far fa-bookmark"></i></button>
                </div>
                <div class="job-title-redesign" style="font-size: 1.15rem; margin-bottom: 6px;"><%= jobs[i].title %></div>
                <div class="job-company" style="margin-bottom: 14px;"><i class="fas fa-building"></i> Company · <%= jobs[i].location %></div>
                <div class="tag-row">
                    <span class="tag tag-orange"><%= jobs[i].jobType %></span>
                    <span class="tag tag-green">Full-time</span>
                </div>
                <div class="job-card-footer" style="padding-top: 20px;">
                    <div class="job-stipend">₹<%= jobs[i].stipend || 25000 %> <span>/ mo</span></div>
                    <a href="/student/job/<%=jobs[i]._id%>" class="btn-redesign btn-ghost-redesign" style="padding: 8px 16px; font-size: 0.8rem;">View Details</a>
                </div>
            </div>
        <% } %>
    </div>

    <div style="height: 60px;"></div>

    <!-- EXTRA CTAs -->
    <div class="cta-banner-redesign fade-in" style="padding: 50px; border-radius: 20px;">
        <div class="cta-text-redesign">
            <h2>Land Your Dream Internship</h2>
            <p>Upload your resume and get noticed by top hiring managers today.</p>
        </div>
        <div class="cta-actions-redesign">
            <a href="/student/profile" class="btn-redesign btn-white"><i class="fas fa-paper-plane"></i> Update Profile</a>
            <a href="/student/myapplication" class="btn-redesign btn-outline-white">Applied Jobs</a>
        </div>
    </div>
</div>

<style>
    .jobs-grid-redesign::-webkit-scrollbar {
        display: none;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const fades = document.querySelectorAll('.fade-in');
        fades.forEach((el, index) => {
            setTimeout(() => {
                el.classList.add('visible');
            }, 100 * index);
        });
    });
</script>
