<div class="container" style="margin-top: 20px;">
    <% if(success && success.length) { %>
        <div class="alert-redesign alert-success-redesign alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i>
            <div><%= success %></div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="font-size: 0.8rem; margin-top: 2px;"></button>
        </div>
    <% } %>

    <% if(error && error.length) { %>
        <div class="alert-redesign alert-error-redesign alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i>
            <div><%= error %></div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="font-size: 0.8rem; margin-top: 2px;"></button>
        </div>
    <% } %>
</div>