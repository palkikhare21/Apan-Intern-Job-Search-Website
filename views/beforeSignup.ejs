<%- layout("/layouts/mainboilerplate.ejs") %>

<div class="auth-section">
    <div class="auth-bg-gradient"></div>
    
    <div class="auth-container-redesign">
        <div class="auth-header-redesign fade-in">
            <div class="hero-badge" style="margin-left:auto;margin-right:auto;">✦ Your Future Starts Here</div>
            <h2>Join ApnaIntern</h2>
            <p>Select your path to continue. Are you looking to hire top talent or find your dream internship?</p>
        </div>

        <div class="selection-grid-redesign fade-in">
            <!-- Company Card -->
            <a href="/company/signup" class="selection-card-redesign">
                <div class="icon-circle">🏢</div>
                <h3>For Employers</h3>
                <p>Hire the best talent across India. Post internships, manage applications, and grow your team effortlessly.</p>
                <div class="btn-redesign btn-ghost-redesign" style="width:100%;justify-content:center;">Continue as Employer</div>
            </a>

            <!-- Student Card -->
            <a href="/student/signup" class="selection-card-redesign">
                <div class="icon-circle">🎓</div>
                <h3>For Students</h3>
                <p>Find your dream internship or first job. Get discovered by top companies and kickstart your career.</p>
                <div class="btn-redesign btn-primary-redesign" style="width:100%;justify-content:center;">Continue as Student</div>
            </a>
        </div>

        <div class="auth-footer fade-in" style="margin-top:48px;">
            Already have an account? <a href="/login">Login here</a>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const fades = document.querySelectorAll('.fade-in');
        fades.forEach((el, index) => {
            setTimeout(() => {
                el.classList.add('visible');
            }, 150 * index);
        });
    });
</script>